# 数据库连接
DATABASE_DSN=

# 推送方式：email / feishu / none
PUSH_CHANNEL=email

# SMTP 邮件推送配置
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# 飞书机器人 Webhook 地址
FEISHU_WEBHOOK=

# 飞书签名校验密钥（可选，用于消息安全校验）
FEISHU_SECRET=

# MiniMax AI API Key（可选，用于 AI 生成市场总结）
MINIMAX_API_KEY=

# ── 账户过滤配置 ──
# 允许交易的板块
ALLOW_MAIN_BOARD=true
ALLOW_CHINEXT=false
ALLOW_STAR=false
ALLOW_BSE=false
# 过滤规则
EXCLUDE_ST=true
MIN_PRICE=2
MAX_PRICE=200
MIN_AMOUNT=100000000
